# ---- Database (local Postgres via docker-compose) ----
DB_URL=jdbc:postgresql://localhost:5432/ibms
DB_USER=ibms
DB_PASSWORD=ibms
DB_POOL_SIZE=10

# ---- Backend JWT (issued after Google SSO) ----
JWT_SECRET=change-me-in-prod-use-a-long-random-string
JWT_ISSUER=ibms-backend
JWT_AUDIENCE=ibms-app
JWT_EXPIRES_MINUTES=720

# ---- Google Workspace SSO (OIDC) ----
# Web client ID used to verify the Google ID token audience.
GOOGLE_OAUTH_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ---- Dev auth shortcut (issues a JWT for a seeded user without Google) ----
# NEVER enable in production.
DEV_AUTH_ENABLED=true

# ---- Attachment storage (local-disk adapter; storage_key holds the path) ----
STORAGE_LOCAL_DIR=./storage

# ---- Integrations (optional locally; features degrade to simulated) ----
GEMINI_API_KEY=
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
APP_URL=http://localhost:8080

# ---- CORS (Wasm client origin, comma-separated) ----
CORS_ALLOWED_HOSTS=localhost:8081
