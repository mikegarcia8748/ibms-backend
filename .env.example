# ---- Database (local Postgres via docker-compose) ----
DB_URL=jdbc:postgresql://localhost:5432/ibms
DB_USER=ibms
DB_PASSWORD=ibms
DB_POOL_SIZE=10

# ---- Backend JWT (access token minted when a session starts) ----
JWT_SECRET=change-me-in-prod-use-a-long-random-string
JWT_ISSUER=ibms-backend
JWT_AUDIENCE=ibms-app
# Short-lived: long sessions are carried by the refresh token, not this one.
JWT_EXPIRES_MINUTES=60

# ---- Password authentication ----
# bcrypt work factor. Raise as hardware improves; existing hashes keep verifying
# at the cost they were written with.
BCRYPT_COST=12
# How long a sysadmin-issued temporary password stays redeemable.
TEMP_PASSWORD_TTL_HOURS=72
# Refresh-token lifetime; revocable at any time from the sessions table.
REFRESH_TOKEN_TTL_DAYS=30
# Lifetime of the one-shot token that authorizes POST /auth/password/change.
PASSWORD_CHALLENGE_TTL_MINUTES=10
# Failed logins before the account is locked, and for how long.
MAX_FAILED_LOGINS=5
LOGIN_LOCKOUT_MINUTES=15

# ---- First-run bootstrap ----
# The seeded sysadmin (V3) has no password. On the first startup where that is
# still true, this password is installed and flagged must-change. Leave it unset
# and the backend generates one and logs it exactly once. Ignored once a password
# exists, so it cannot be used to take over a live account.
BOOTSTRAP_ADMIN_EMAIL=mike.pgmobiledev@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=

# ---- Attachment storage (local-disk adapter; storage_key holds the path) ----
STORAGE_LOCAL_DIR=./storage

# ---- Integrations (optional locally; features degrade to simulated) ----
GEMINI_API_KEY=
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
APP_URL=http://localhost:8080

# ---- CORS (Wasm client origin, comma-separated) ----
CORS_ALLOWED_HOSTS=localhost:8081
